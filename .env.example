# Stock-ARM 配置文件模板
# 复制此文件为 .env 并填写实际值
# 优先级: 环境变量 > .env > config.yaml > 代码默认值

# ===== LLM 配置 =====
# 必填: 至少配置一个 LLM API Key
STOCK_ARM_LLM_API_KEY=           # 主 LLM API Key（必填）
STOCK_ARM_LLM_PRIMARY_MODEL=deepseek-chat  # 主模型名称
STOCK_ARM_LLM_FAST_MODEL=glm-4-flash      # 快速模型（批量任务用）
STOCK_ARM_LLM_DAILY_TOKEN_LIMIT=500000     # 每日 Token 预算（0=不限）

# ===== 数据源 =====
STOCK_ARM_DATA_TUSHARE_TOKEN=    # 可选: Tushare Pro Token
STOCK_ARM_DATA_CONNECT_TIMEOUT=5 # 连接超时（秒）
STOCK_ARM_DATA_READ_TIMEOUT=30   # 读取超时（秒）
STOCK_ARM_DATA_MAX_RETRIES=3     # 最大重试次数

# ===== 网络 =====
STOCK_ARM_NET_PROXY=             # 代理地址，例如 socks5://127.0.0.1:1080

# ===== 运行时 =====
STOCK_ARM_RUNTIME_ENV=auto       # auto | cloud | docker | local
STOCK_ARM_DATA_DIR=              # 数据目录覆盖（默认: ./data）
STOCK_ARM_LOG_LEVEL=INFO         # 日志级别: DEBUG | INFO | WARNING | ERROR
STOCK_ARM_LOG_TO_STDOUT=false    # 是否同时输出到 stdout（cloud/docker 自动开启）
STOCK_ARM_BIND_HOST=127.0.0.1   # 绑定地址（cloud/docker 自动切换为 0.0.0.0）
STOCK_ARM_PORT=8000              # 服务端口

# ===== 云端模式（仅当 RUNTIME_ENV=cloud 时生效）=====
STOCK_ARM_AUTH_ENABLED=false     # 启用 Web UI 密码认证
STOCK_ARM_AUTH_USERNAME=admin    # 认证用户名
STOCK_ARM_AUTH_PASSWORD=         # 认证密码（启用认证时必填）
STOCK_ARM_SSL_CERT_PATH=        # 可选: SSL 证书路径
STOCK_ARM_SSL_KEY_PATH=         # 可选: SSL 私钥路径
STOCK_ARM_BACKUP_ENABLED=false  # 可选: 定时数据库备份
STOCK_ARM_BACKUP_PATH=          # 备份目标目录
STOCK_ARM_BACKUP_CRON=0 3 * * * # 备份计划（cron 格式）

# ===== 调度器 =====
STOCK_ARM_SCHEDULER_ENABLED=true
STOCK_ARM_SCHEDULE_DAILY_ANALYSIS=18:00
STOCK_ARM_SCHEDULE_DAILY_MACRO=18:30
STOCK_ARM_SCHEDULE_DAILY_BRIEFING=19:00
STOCK_ARM_SCHEDULE_EARNINGS_SCAN=20:00
STOCK_ARM_SCHEDULE_MONTHLY_REPORT=09:00
STOCK_ARM_TRADING_DAY_CHECK=true       # 非交易日跳过
STOCK_ARM_DATA_RETENTION_DAYS=90       # 自动清理超过 N 天的数据
STOCK_ARM_CLEANUP_CRON=0 3 1 * *       # 清理计划

# ===== 推送通知 =====
STOCK_ARM_PUSH_SCHEDULE_TIME=18:00     # 推送时间
STOCK_ARM_PUSH_SILENT_START=22:00      # 免打扰开始
STOCK_ARM_PUSH_SILENT_END=08:00        # 免打扰结束
